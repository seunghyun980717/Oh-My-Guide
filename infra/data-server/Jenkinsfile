pipeline {
    agent any

    triggers {
        gitlab(
            triggerOnPush: false,
            triggerOnMergeRequest: false,
            triggerOnAcceptedMergeRequest: true,
            branchFilterType: 'NameBasedFilter',
            includeBranchesSpec: 'master'
        )
    }

    environment {
        DATA_SERVER_HOST = 'ubuntu@j14e103.p.ssafy.io'
        DATA_SERVER_DIR  = '/home/ubuntu/data-server'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Detect Changes') {
            steps {
                script {
                    def changedFiles = sh(
                        script: 'git diff --name-only HEAD~1 HEAD',
                        returnStdout: true
                    ).trim()
                    echo "Changed files:\n${changedFiles}"

                    def sparkJobsChanged = changedFiles.split('\n').any { it.startsWith('infra/data-server/spark-jobs/') }
                    env.SPARK_JOBS_CHANGED = sparkJobsChanged ? 'true' : 'false'

                    def infraChanged = changedFiles.split('\n').any {
                        it.startsWith('infra/data-server/livy/') ||
                        it == 'infra/data-server/docker-compose.hadoop.yml' ||
                        it.startsWith('infra/data-server/hadoop-config/')
                    }
                    env.INFRA_CHANGED = infraChanged ? 'true' : 'false'
                }
            }
        }

        stage('Deploy Spark Jobs') {
            when {
                environment name: 'SPARK_JOBS_CHANGED', value: 'true'
            }
            steps {
                sshagent(['data-server-ssh-key']) {
                    sh '''
                        rsync -avz --delete \
                            -e "ssh -o StrictHostKeyChecking=no" \
                            infra/data-server/spark-jobs/ \
                            $DATA_SERVER_HOST:$DATA_SERVER_DIR/spark-jobs/
                    '''
                }
            }
        }

        stage('Deploy Infra') {
            when {
                environment name: 'INFRA_CHANGED', value: 'true'
            }
            steps {
                sshagent(['data-server-ssh-key']) {
                    sh '''
                        rsync -avz --delete \
                            -e "ssh -o StrictHostKeyChecking=no" \
                            infra/data-server/livy/ \
                            $DATA_SERVER_HOST:$DATA_SERVER_DIR/livy/

                        rsync -avz \
                            -e "ssh -o StrictHostKeyChecking=no" \
                            infra/data-server/docker-compose.hadoop.yml \
                            $DATA_SERVER_HOST:$DATA_SERVER_DIR/docker-compose.hadoop.yml

                        rsync -avz \
                            -e "ssh -o StrictHostKeyChecking=no" \
                            infra/data-server/hadoop-config/ \
                            $DATA_SERVER_HOST:$DATA_SERVER_DIR/hadoop-config/

                        ssh -o StrictHostKeyChecking=no $DATA_SERVER_HOST \
                            "cd $DATA_SERVER_DIR && docker compose -f docker-compose.hadoop.yml up -d --build"
                    '''
                }
            }
        }
    }

    post {
        success {
            script {
                if (env.SPARK_JOBS_CHANGED == 'true') {
                    withCredentials([string(credentialsId: 'mattermost-webhook-url', variable: 'WEBHOOK_URL')]) {
                        def msg = "✅ **Spark Jobs 배포 성공**\n- Job: ${env.JOB_NAME}\n- Build: #${env.BUILD_NUMBER}\n- Branch: ${env.GIT_BRANCH}"
                        def payload = groovy.json.JsonOutput.toJson([text: msg])
                        sh "curl -s -X POST \"\$WEBHOOK_URL\" -H 'Content-Type: application/json' -d '${payload}'"
                    }
                }
            }
        }
        failure {
            script {
                if (env.SPARK_JOBS_CHANGED == 'true') {
                    withCredentials([string(credentialsId: 'mattermost-webhook-url', variable: 'WEBHOOK_URL')]) {
                        def msg = "❌ **Spark Jobs 배포 실패**\n- Job: ${env.JOB_NAME}\n- Build: #${env.BUILD_NUMBER}\n- Branch: ${env.GIT_BRANCH}\n- URL: ${env.BUILD_URL}"
                        def payload = groovy.json.JsonOutput.toJson([text: msg])
                        sh "curl -s -X POST \"\$WEBHOOK_URL\" -H 'Content-Type: application/json' -d '${payload}'"
                    }
                }
            }
        }
    }
}
