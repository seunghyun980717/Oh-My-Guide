<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration>
  <!--
    복제 팩터: DataNode가 1개이므로 1로 설정
    (운영 환경에서는 3 권장)
  -->
  <property>
    <name>dfs.replication</name>
    <value>1</value>
  </property>

  <!--
    NameNode 데이터 저장 경로
  -->
  <property>
    <name>dfs.namenode.name.dir</name>
    <value>/opt/hadoop/data/nameNode</value>
  </property>

  <!--
    DataNode 데이터 저장 경로
  -->
  <property>
    <name>dfs.datanode.data.dir</name>
    <value>/opt/hadoop/data/dataNode</value>
  </property>

  <!--
    DataNode가 외부(Spring Boot, Spark)에서 접근 가능하도록
    hostname 대신 IP/외부주소 사용 허용
  -->
  <property>
    <name>dfs.client.use.datanode.hostname</name>
    <value>true</value>
  </property>

  <!--
    DataNode가 외부 클라이언트에게 광고할 hostname
    내부 Docker IP(172.x.x.x) 대신 외부 IP를 반환하도록 설정
    → app server(Spring Boot)에서 DataNode에 직접 접근 가능
    환경변수로 분리: 운영=43.203.244.30, 로컬=localhost
  -->
  <property>
    <name>dfs.datanode.hostname</name>
    <value>${env.DATANODE_HOSTNAME}</value>
  </property>

  <!--
    DataNode HTTP 포트 (Web UI 및 데이터 전송)
  -->
  <property>
    <name>dfs.datanode.http.address</name>
    <value>0.0.0.0:9864</value>
  </property>

  <!--
    DataNode 데이터 전송 포트
  -->
  <property>
    <name>dfs.datanode.address</name>
    <value>0.0.0.0:9866</value>
  </property>

  <!--
    DataNode IPC 포트
  -->
  <property>
    <name>dfs.datanode.ipc.address</name>
    <value>0.0.0.0:9867</value>
  </property>

  <!--
    Web UI 접근 권한: 모든 IP 허용
  -->
  <property>
    <name>dfs.permissions.enabled</name>
    <value>false</value>
  </property>

  <!--
    Safe mode 자동 해제 (단일 DataNode 환경)
  -->
  <property>
    <name>dfs.namenode.safemode.threshold-pct</name>
    <value>0.0</value>
  </property>

  <!--
    DataNode 등록 시 IP-hostname 검증 비활성화
    로컬 개발 환경에서 DataNode hostname(localhost)과 실제 IP(172.x.x.x) 불일치로
    hostname이 무시되는 문제 방지
  -->
  <property>
    <name>dfs.namenode.datanode.registration.ip-hostname-check</name>
    <value>false</value>
  </property>
</configuration>
