# =============================================================================
# Oh! My Guide — 로컬 실행 환경변수 템플릿
# =============================================================================
# 사용법: cp exec/.env.example exec/.env  후 <값> 부분을 실제 값으로 교체
# 주의:  .env 파일은 절대 커밋하지 마세요 (.gitignore 에 등록되어 있습니다)
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=1234
POSTGRES_DB=ohmyguide

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=<Grafana 관리자 비밀번호>

# ── Spring Boot: Google OAuth2 ────────────────────────────────────────────────
# Google Cloud Console → API 및 서비스 → 사용자 인증 정보에서 발급
GOOGLE_CLIENT_ID=<Google OAuth2 Client ID>
GOOGLE_CLIENT_SECRET=<Google OAuth2 Client Secret>

# ── Spring Boot: JWT ──────────────────────────────────────────────────────────
# 256비트(32바이트) 이상의 랜덤 문자열
# 생성 예시: openssl rand -hex 32
TOKEN_SECRET=<JWT 시크릿 키>

# ── Spring Boot: 한국관광공사 API ─────────────────────────────────────────────
# https://www.data.go.kr 에서 "한국관광공사 국문 관광정보 서비스" 신청 후 발급
TOUR_API_KEY=<한국관광공사 API 서비스 키>

# ── AI 서버: SSAFY GMS (Gen AI Management System) ────────────────────────────
GMS_KEY=<GMS API 키>
GMS_BASE_URL=https://gms.ssafy.io/gmsapi
