# ===== PostgreSQL =====
DB_HOST=postgresql
DB_PORT=5432
DB_NAME=ohmyguide
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379

# ===== Kafka =====
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID=oh-my-guide

# ===== OAuth2 =====
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===== JWT =====
JWT_SECRET=your_jwt_secret_key_at_least_256_bits
JWT_EXPIRATION=86400000

# ===== HDFS =====
HDFS_HOST=localhost
HDFS_PORT=9000
HDFS_USER=root

# ===== Livy (Spark Job 제출) =====
LIVY_URL=http://43.203.244.30:8998
SPARK_SCHEDULE_ENABLED=false

# Spark에서 PostgreSQL 접근 시 사용할 호스트 (Data 서버 → App 서버 DB)
# 로컬: 미설정 (자동으로 host.docker.internal 사용)
# 운영: 43.200.1.94 (App 서버 공인 IP)
SPARK_DB_HOST=
